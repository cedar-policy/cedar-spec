# Don't check in the local metadata file.
.DS_Store

# Don't check in ide settings by accident
.idea
.kiro
.claude
# VSCode settings -- use .vscode/settings.json.default for recommended config;
# local .vscode/ is ignored so developer overrides stay untracked
.vscode/*
!.vscode/settings.json.default

# Don't check in the Emacs temp files
*~

# Don't check in test framework files
.attach_pid*

# Don't check IntelliJ module files
*.iml

# Rust build artifacts
**/target
**/Cargo.lock
# Fuzzing artifacts
cedar-drt/fuzz/corpus
cedar-drt/fuzz/artifacts
cedar-drt/fuzz_reports

# We expect a copy of `cedar-policy/cedar` present in this directory, but do
# not track it in version control.
cedar/
!cedar-lean/Cedar
